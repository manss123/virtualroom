datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

generator client {
    provider = "prisma-client-js"
}

model User {
    id           String              @id @default(cuid())
    firstName    String
    lastName     String
    sex          String? // "M" | "F" | etc.
    age          Int?
    school       String?
    grade        String? // ระดับชั้น เช่น ม.3
    email        String?             @unique
    identities   AuthIdentity[]
    prePostTests PrePostTest[]
    selfRegs     SelfRegAssessment[]
    roomPlans    RoomPlan[]
    studyLogs    RoomStudyLog[]
    createdAt    DateTime            @default(now())
    updatedAt    DateTime            @updatedAt
}

model AuthIdentity {
    id             String  @id @default(cuid())
    userId         String
    provider       String // "local" | "google"
    providerUserId String? // sub จาก Google
    email          String? // สำหรับ local / google
    passwordHash   String? // เฉพาะ local
    user           User    @relation(fields: [userId], references: [id])

    @@unique([provider, providerUserId])
    @@unique([provider, email])
}

enum PrePostType {
    PRE
    POST
}

model PrePostTest {
    id         String      @id @default(cuid())
    userId     String
    type       PrePostType
    totalItems Int         @default(17)
    score      Int
    takenAt    DateTime    @default(now())
    user       User        @relation(fields: [userId], references: [id])
}

model SelfRegAssessment {
    id         String   @id @default(cuid())
    userId     String
    totalItems Int      @default(46)
    score      Int
    takenAt    DateTime @default(now())
    user       User     @relation(fields: [userId], references: [id])
}

model RoomPlan {
    id          String   @id @default(cuid())
    userId      String
    roomKey     String // เช่น "room_a"
    plannedDate DateTime
    createdAt   DateTime @default(now())
    user        User     @relation(fields: [userId], references: [id])

    @@index([userId, roomKey])
}

model RoomStudyLog {
    id          String   @id @default(cuid())
    userId      String
    roomKey     String
    startAt     DateTime
    endAt       DateTime
    durationSec Int?
    user        User     @relation(fields: [userId], references: [id])

    @@index([userId, roomKey, startAt])
}
